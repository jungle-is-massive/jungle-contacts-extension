{
  "manifest_version": 3,
  "name": "Jungle Intermediary Contacts",
  "version": "1.0.0",
  "description": "Save LinkedIn contacts straight to the Jungle Intermediary Plan.",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://iehkvlyjumkzccoqqgxl.supabase.co/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Jungle: Save this contact",
    "default_icon": {
      "16": "icon-16.png",
      "32": "icon-32.png",
      "48": "icon-48.png",
      "128": "icon-128.png"
    }
  },
  "icons": {
    "16": "icon-16.png",
    "32": "icon-32.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/in/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
